# a11y-scout Environment Configuration
# Copy this file to .env and fill in your values

# Required for AI-powered AAA checks only
# A/AA levels work without HAIP (uses axe-core)
# HAIP_API_KEY=your-haip-key-here
# HAIP_ENVIRONMENT_ID=your-env-id
# HAIP_USER_ID=your-user-id

# Optional: mock mode (disables HAIP, axe-core still works)
# A11Y_HAIP_MOCK=1

# Optional: maximum HAIP cost per scan (default: $1.00)
# A11Y_MAX_COST_USD=1.00
